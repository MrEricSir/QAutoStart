project = QAutoStart
description = Cross-platform Qt auto-start on login
version = 1.0.0

headerdirs = ../src
sourcedirs = ../src

headers.fileextensions = "*.h"
sources.fileextensions = "*.cpp"

includepaths += $QT_INSTALL_HEADERS \
                $QT_INSTALL_HEADERS/QtCore

outputdir = html
outputformats = HTML
